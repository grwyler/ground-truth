# Application
APP_ENV=development
WEB_ORIGIN=http://localhost:3000
API_PORT=4000

# Database / persistence
DATABASE_URL=postgres://user:password@localhost:5432/ground_truth

# Document storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=.data/uploads

# AI draft generation
AI_PROVIDER=mock
AI_API_KEY=

# Authentication
AUTH_PROVIDER=local
AUTH_ISSUER=http://localhost:4000/auth

# Jira integration
JIRA_BASE_URL=https://example.atlassian.net
JIRA_PROJECT_KEY=READY
JIRA_API_TOKEN=
